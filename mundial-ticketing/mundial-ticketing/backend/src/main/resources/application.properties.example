# ============================================================
#  SERVIDOR
# ============================================================
server.port=8080

# ============================================================
#  BASE DE DATOS MySQL
#  Ajustar host, puerto, nombre de BD, usuario y contraseña
#  según el entorno que configure el compañero de BD.
# ============================================================
spring.datasource.url=jdbc:mysql://localhost:3306/mundial_ticketing?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=TU_PASSWORD_LOCAL_AQUI
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# Pool de conexiones (HikariCP viene por defecto con Spring Boot)
spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=2
spring.datasource.hikari.connection-timeout=30000

# ============================================================
#  JWT
#  IMPORTANTE: cambiar jwt.secret por una cadena larga y
#  aleatoria antes de cualquier despliegue real.
# ============================================================
jwt.secret=TU_SECRETO_LARGO_Y_ALEATORIO_AQUI
jwt.expiration-ms=86400000

# ============================================================
#  LOGGING
# ============================================================
logging.level.com.ucu.ticketing=DEBUG
logging.level.org.springframework.jdbc=DEBUG
